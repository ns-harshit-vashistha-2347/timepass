# =========================================================
# MONOREPO .gitignore
# Covers:
# - FastAPI Backend (Python)
# - React Frontend (Vite / CRA / Next-compatible)
# - Docker
# - VS Code / JetBrains
# - Logs / Environment files
# =========================================================

# =========================================================
# PYTHON / FASTAPI BACKEND
# =========================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Python distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# Pip
pip-log.txt
pip-delete-this-directory.txt

# Pytest
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Type checking
.mypy_cache/
.pyre/
.pytype/

# Ruff / Linting
.ruff_cache/

# Jupyter Notebook
.ipynb_checkpoints/

# FastAPI / Uvicorn
*.log

# SQLite
*.sqlite3
*.db

# Environment variables
.env
.env.*
!.env.example

# Secrets
secrets/
*.pem
*.key

# Cache
.cache/

# =========================================================
# NODE / REACT FRONTEND
# =========================================================

# Dependencies
node_modules/

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build folders
dist/
build/
.next/
out/

# Vite
.vite/

# Coverage
coverage/

# Environment files
frontend/.env
frontend/.env.*
!.env.example

# Parcel
.cache/
.parcel-cache/

# TurboRepo
.turbo/

# =========================================================
# DOCKER
# =========================================================

# Docker override files
docker-compose.override.yml

# Docker volumes
*.tar

# =========================================================
# DATABASES
# =========================================================

# PostgreSQL local data
postgres_data/
pgdata/

# Redis
redis_data/

# =========================================================
# IDE / EDITOR
# =========================================================

# VS Code
.vscode/

# JetBrains
.idea/

# Sublime
*.sublime-workspace
*.sublime-project

# Mac
.DS_Store

# Windows
Thumbs.db
Desktop.ini

# =========================================================
# TEMP FILES
# =========================================================

*.tmp
*.temp
*.swp
*.swo
*~

# =========================================================
# TEST OUTPUTS
# =========================================================

coverage.xml
nosetests.xml

# =========================================================
# MISC
# =========================================================

# Local runtime files
*.pid

# Ignore generated static/media if needed
media/
staticfiles/

# AI / ML
wandb/
mlruns/
checkpoints/